# LeoHoca - Environment Configuration
# 100% ücretsiz — 0 maliyet. Groq veya Ollama.

# === BULUT - HERKESE AÇIK (ÜCRETSİZ) ===
# Groq: https://console.groq.com - Ücretsiz API key
# Deploy: Railway, Render, Fly.io - GROQ_API_KEY ekleyin
GROQ_API_KEY=gsk_xxx

# === YEREL - SADECE KENDİ BİLGİSAYARINIZ (0 maliyet) ===
# Ollama: https://ollama.com - API key gerekmez
# OLLAMA_MODEL=llama3.2

# Şifre koruması (opsiyonel) - Sadece şifreyi bilenler kullanabilir
# LEOHOCA_PASSWORD=guvenli_sifre

# Admin hesabı - İlk kurulumda oluşturulur
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=guvenli_admin_sifre

# JWT secret (production'da mutlaka değiştirin)
# JWT_SECRET=rastgele_uzun_anahtar

# Veritabanı yolu (opsiyonel, varsayılan: server/data/leogpt.db)
# DATABASE_PATH=/path/to/leogpt.db

# === Görsel üretim (Stable Diffusion / Fooocus — ücretsiz) ===
# IMAGE_GEN_URL=http://localhost:7860   # AUTOMATIC1111
# IMAGE_GEN_URL=http://localhost:7865   # Fooocus
# IMAGE_GEN_BACKEND=fooocus

# === Meta / Instagram ===
# META_APP_ID=xxx
# META_APP_SECRET=xxx
# INSTAGRAM_REDIRECT_URI=https://domain/api/instagram/callback

PORT=3100
